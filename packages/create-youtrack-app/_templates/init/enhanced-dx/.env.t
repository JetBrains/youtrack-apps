---
to: .env
---
# YouTrack API Configuration
# Replace with your actual YouTrack permanent token
# Get your token from: https://www.jetbrains.com/help/youtrack/server/manage-permanent-token.html
YOUTRACK_TOKEN=perm:your-token-here

# YouTrack Host URL
# Replace with your YouTrack instance URL
YOUTRACK_HOST=http://localhost:8088
