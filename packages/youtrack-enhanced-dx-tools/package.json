{
  "name": "@jetbrains/youtrack-enhanced-dx-tools",
  "version": "0.0.1",
  "type": "module",
  "description": "Enhanced DX tools and plugins for YouTrack apps with TypeScript support",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/JetBrains/youtrack-apps.git"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "youtrack-upload-coordinator": "./dist/cli/upload-coordinator.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./runtime": {
      "types": "./dist/runtime.d.ts",
      "import": "./dist/runtime.js"
    },
    "./api": {
      "types": "./dist/api/index.d.ts",
      "import": "./dist/api/index.js"
    },
    "./youtrack-types": {
      "types": "./youtrack-types.d.ts",
      "default": "./youtrack-types.d.ts"
    },
    "./youtrack-workflow-api": {
      "types": "./youtrack-workflow-api/index.d.ts",
      "default": "./youtrack-workflow-api/index.d.ts"
    },
    "./youtrack-workflow-api/*": {
      "types": "./youtrack-workflow-api/*.d.ts",
      "default": "./youtrack-workflow-api/*.d.ts"
    }
  },
  "files": [
    "dist",
    "src",
    "templates",
    "youtrack-types.d.ts",
    "youtrack-workflow-api"
  ],
  "author": "JetBrains",
  "license": "Apache-2.0",
  "dependencies": {
    "chokidar": "^4.0.3",
    "fast-glob": "^3.3.3",
    "fs-extra": "^11.3.0",
    "ts-morph": "^26.0.0",
    "ts-to-zod": "^3.15.0",
    "vite": "^6.0.1",
    "vite-tsconfig-paths": "^5.1.4"
  },
  "devDependencies": {
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^24.0.14",
    "tsx": "^4.8.1",
    "typescript": "^5.7.2"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "lint": "eslint src --ext .ts",
    "test": "npm run build && node --test --import tsx test/*.test.ts",
    "test:watch": "node --test --watch --import tsx test/*.test.ts",
    "prepare": "npm run build"
  },
  "engines": {
    "node": ">=18.20.4"
  }
}
