{
  "compilerOptions": {
    "lib": ["es2023"],
    "target": "es2022",
    "skipLibCheck": true,
    "strict": true,
    "noImplicitAny": true,
    "removeComments": true,
    "declaration": true,
    "module": "ESNext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "importHelpers": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "types": ["node"],
    "outDir": "dist"
  },
  "include": ["src", "lib", "index.ts"],
  "exclude": ["node_modules", "dist", "**/*.test.*", "src/dx/test/**"]
}
